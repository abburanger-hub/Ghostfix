# ==============================================================================
# GhostFix — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# SUPABASE
# Find these in: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------------------------

# The public URL of your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon/public key (safe to expose to the browser — enforces RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The service_role key — NEVER expose this to the browser.
# Used ONLY in server-side API routes to bypass RLS for trusted operations.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------------------------
# ------------------------------------------------------------------------------
# GROQ (AI triage engine)
# Sign up free at: https://console.groq.com — no billing required
# Powers: llama-3.3-70b-versatile (30 req/min, 14,400 req/day free)
# ------------------------------------------------------------------------------
GROQ_API_KEY=gsk_your-groq-api-key-here

# ------------------------------------------------------------------------------
# WEBHOOK SECURITY (Optional but recommended for production)
# Shared secret for the x-ghostfix-secret header on POST /api/ingest.
# Set to any strong random string, e.g.: openssl rand -hex 32
# Default dev value (already set in the app): dev-secret
# ------------------------------------------------------------------------------
GHOSTFIX_WEBHOOK_SECRET=your-strong-random-secret-here

# ------------------------------------------------------------------------------
# GHOST ENVIRONMENT BASE URL
# The base URL prepended to every generated hotfix link.
# In development:  http://localhost:3000/patch
# In production:   https://ghostfix.vercel.app/patch  (or your custom domain)
# ------------------------------------------------------------------------------
GHOST_ENV_BASE_URL=https://ghostfix.vercel.app/patch

# ------------------------------------------------------------------------------
# RESEND (Transactional email)
# Sign up free at: https://resend.com — 3,000 emails/month free tier.
# Steps:
#   1. Create an account at resend.com
#   2. Copy your API key from the dashboard → paste below
#   3. (Optional) Add + verify your domain, then set RESEND_FROM
#      Without a verified domain, emails only deliver to your Resend account
#      owner email (fine for hackathon demos).
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_your_key_here
RESEND_FROM=GhostFix <noreply@yourdomain.com>
