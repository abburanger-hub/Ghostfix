# ==============================================================================
# GhostFix — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# SUPABASE
# Find these in: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------------------------

# The public URL of your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon/public key (safe to expose to the browser — enforces RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The service_role key — NEVER expose this to the browser.
# Used ONLY in server-side API routes to bypass RLS for trusted operations.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------------------------
# OPENAI
# Find this in: https://platform.openai.com/api-keys
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here

# ------------------------------------------------------------------------------
# WEBHOOK SECURITY (Optional but recommended for production)
# A shared secret you configure in Zoho Desk / Zoho Cliq webhook settings.
# GhostFix will reject any request that doesn't include this header.
# Set to any strong random string, e.g.: openssl rand -hex 32
# ------------------------------------------------------------------------------
GHOSTFIX_WEBHOOK_SECRET=your-strong-random-secret-here

# ------------------------------------------------------------------------------
# GHOST ENVIRONMENT BASE URL
# The base URL prepended to every generated hotfix link.
# In development: http://localhost:3000/patch
# In production: https://ghostfix.app/patch  (or your Vercel deployment URL)
# ------------------------------------------------------------------------------
GHOST_ENV_BASE_URL=https://ghostfix.app/patch
